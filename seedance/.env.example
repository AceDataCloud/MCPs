# Environment template - copy to .env and fill in your values
# Get your API token from https://platform.acedata.cloud

# AceDataCloud API Configuration (REQUIRED)
ACEDATACLOUD_API_TOKEN=your_api_token_here
ACEDATACLOUD_API_BASE_URL=https://api.acedata.cloud

# Seedance Configuration (Optional)
SEEDANCE_DEFAULT_MODEL=doubao-seedance-1-0-pro-250528
SEEDANCE_DEFAULT_RESOLUTION=720p
SEEDANCE_DEFAULT_RATIO=16:9
SEEDANCE_DEFAULT_DURATION=5
SEEDANCE_REQUEST_TIMEOUT=1800

# MCP Server Configuration (Optional)
MCP_SERVER_NAME=seedance
MCP_TRANSPORT=stdio

# Logging (Optional)
LOG_LEVEL=INFO
