{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.AceDataCloud/mcp-maestro",
  "description": "Produce complete AI videos from a brief with Maestro",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/AceDataCloud/MaestroMCP",
    "source": "github"
  },
  "packages": [
    {
      "identifier": "mcp-maestro",
      "version": "0.1.0",
      "transport": { "type": "stdio" },
      "registryType": "pypi",
      "runtimeHint": "uvx",
      "environmentVariables": [
        {
          "name": "ACEDATACLOUD_API_TOKEN",
          "description": "API token from Ace Data Cloud (https://platform.acedata.cloud)",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "websiteUrl": "https://maestro.mcp.acedata.cloud",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://maestro.mcp.acedata.cloud/mcp"
    }
  ]
}