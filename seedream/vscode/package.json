{
  "name": "mcp-seedream",
  "displayName": "Seedream MCP",
  "description": "Seedream by ByteDance — text-to-image and SeedEdit instruction-based editing.",
  "version": "0.3.0",
  "publisher": "acedatacloud",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "ai",
    "copilot",
    "ace data cloud",
    "seedream",
    "bytedance",
    "image generation",
    "seededit",
    "image editing"
  ],
  "galleryBanner": {
    "color": "#0E1117",
    "theme": "dark"
  },
  "homepage": "https://github.com/AceDataCloud/SeedreamMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/AceDataCloud/SeedreamMCP"
  },
  "bugs": {
    "url": "https://github.com/AceDataCloud/SeedreamMCP/issues"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "acedatacloud.seedream",
        "label": "Seedream MCP"
      }
    ],
    "commands": [
      {
        "command": "acedatacloud.seedream.setApiToken",
        "title": "Seedream MCP: Set Ace Data Cloud API Token",
