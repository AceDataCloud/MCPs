{
  "name": "mcp-sora",
  "displayName": "Sora MCP",
  "description": "OpenAI Sora video generation — text-to-video, image-to-video, character references.",
  "version": "0.3.0",
  "publisher": "acedatacloud",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "ai",
    "copilot",
    "ace data cloud",
    "sora",
    "openai",
    "video generation",
    "text to video"
  ],
  "galleryBanner": {
    "color": "#0E1117",
    "theme": "dark"
  },
  "homepage": "https://github.com/AceDataCloud/SoraMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/AceDataCloud/SoraMCP"
  },
  "bugs": {
    "url": "https://github.com/AceDataCloud/SoraMCP/issues"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "acedatacloud.sora",
        "label": "Sora MCP"
      }
    ],
    "commands": [
      {
        "command": "acedatacloud.sora.setApiToken",
        "title": "Sora MCP: Set Ace Data Cloud API Token",
        "category": "MCP"
      },
      {
        "command": "acedatacloud.sora.clearApiToken",
        "title": "Sora MCP: Clear Ace Data Cloud API Token",
        "category": "MCP"
      }
    ]
  }
}
