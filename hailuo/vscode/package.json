{
  "name": "mcp-hailuo",
  "displayName": "Hailuo MCP",
  "description": "Hailuo (MiniMax) AI video — text-to-video and image-to-video with director mode.",
  "version": "0.3.0",
  "publisher": "acedatacloud",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "ai",
    "copilot",
    "ace data cloud",
    "hailuo",
    "minimax",
    "video generation",
    "director mode"
  ],
  "galleryBanner": {
    "color": "#0E1117",
    "theme": "dark"
  },
  "homepage": "https://github.com/AceDataCloud/HailuoMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/AceDataCloud/HailuoMCP"
  },
  "bugs": {
    "url": "https://github.com/AceDataCloud/HailuoMCP/issues"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "acedatacloud.hailuo",
        "label": "Hailuo MCP"
      }
    ],
    "commands": [
      {
        "command": "acedatacloud.hailuo.setApiToken",
        "title": "Hailuo MCP: Set Ace Data Cloud API Token",
        "category": "MCP"
      },
      {
        "command": "acedatacloud.hailuo.clearApiToken",
        "title": "Hailuo MCP: Clear Ace Data Cloud API Token",
        "category": "MCP"
      }
    ]
  }
}
