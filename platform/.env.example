# Environment template - copy to .env and fill in your values
# Create a platform token at https://platform.acedata.cloud/console/platform-tokens

# Platform management API (REQUIRED)
# NOTE: this is a PLATFORM token (starts with "platform-"), NOT the
# api.acedata.cloud per-service data token.
ACEDATACLOUD_PLATFORM_TOKEN=your_platform_token_here
PLATFORM_API_BASE_URL=https://platform.acedata.cloud

# Request configuration (optional)
PLATFORM_REQUEST_TIMEOUT=30

# MCP server configuration (optional)
MCP_SERVER_NAME=platform
MCP_TRANSPORT=stdio

# Logging (optional)
LOG_LEVEL=INFO
