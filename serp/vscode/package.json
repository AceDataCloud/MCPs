{
  "name": "mcp-serp",
  "displayName": "Serp MCP",
  "description": "Google Search via Ace Data Cloud — web, images, news, maps, local, video.",
  "version": "0.2.0",
  "publisher": "acedatacloud",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "ai",
    "copilot",
    "ace data cloud",
    "serp",
    "google",
    "search",
    "web search",
    "news",
    "images"
  ],
  "galleryBanner": {
    "color": "#0E1117",
    "theme": "dark"
  },
  "homepage": "https://github.com/AceDataCloud/SerpMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/AceDataCloud/SerpMCP"
  },
  "bugs": {
    "url": "https://github.com/AceDataCloud/SerpMCP/issues"
  },
  "contributes": {
    "mcpServers": {
      "serp": {
        "type": "http",
        "url": "https://serp.mcp.acedata.cloud/mcp",
        "headers": {
          "Authorization": "Bearer ${input:acedatacloud_api_token}"
        }
      }
    },
    "inputs": [
      {
        "type": "promptString",
        "id": "acedatacloud_api_token",
        "description": "Ace Data Cloud API token. Sign in at https://platform.acedata.cloud and create a token in 'API Keys'. Stored securely by VS Code.",
        "password": true
      }
    ]
  }
}
