{
  "name": "mcp-serp",
  "displayName": "Serp MCP",
  "description": "Google Search via Ace Data Cloud — web, images, news, maps, local, video.",
  "version": "0.3.0",
  "publisher": "acedatacloud",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "ai",
    "copilot",
    "ace data cloud",
    "serp",
    "google",
    "search",
    "web search",
    "news",
    "images"
  ],
  "galleryBanner": {
    "color": "#0E1117",
    "theme": "dark"
  },
  "homepage": "https://github.com/AceDataCloud/SerpMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/AceDataCloud/SerpMCP"
  },
  "bugs": {
    "url": "https://github.com/AceDataCloud/SerpMCP/issues"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "acedatacloud.serp",
        "label": "Serp MCP"
      }
    ],
    "commands": [
      {
        "command": "acedatacloud.serp.setApiToken",
        "title": "Serp MCP: Set Ace Data Cloud API Key",
        "category": "MCP"
      },
      {
        "command": "acedatacloud.serp.clearApiToken",
        "title": "Serp MCP: Clear Ace Data Cloud API Key",
        "category": "MCP"
      }
    ]
  }
}
