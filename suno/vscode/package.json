{
  "name": "mcp-suno",
  "displayName": "Suno MCP",
  "description": "AI music generation with Suno — songs, lyrics, covers, stems, and more.",
  "version": "0.3.0",
  "publisher": "acedatacloud",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "ai",
    "copilot",
    "ace data cloud",
    "suno",
    "music",
    "ai music",
    "song generation",
    "lyrics",
    "audio"
  ],
  "galleryBanner": {
    "color": "#0E1117",
    "theme": "dark"
  },
  "homepage": "https://github.com/AceDataCloud/SunoMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/AceDataCloud/SunoMCP"
  },
  "bugs": {
    "url": "https://github.com/AceDataCloud/SunoMCP/issues"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "acedatacloud.suno",
        "label": "Suno MCP"
      }
    ],
    "commands": [
      {
        "command": "acedatacloud.suno.setApiToken",
        "title": "Suno MCP: Set Ace Data Cloud API Key",
        "category": "MCP"
      },
      {
        "command": "acedatacloud.suno.clearApiToken",
        "title": "Suno MCP: Clear Ace Data Cloud API Key",
        "category": "MCP"
      }
    ]
  }
}
