{
  "name": "mcp-suno",
  "displayName": "Suno MCP",
  "description": "AI music generation with Suno — songs, lyrics, covers, stems, and more.",
  "version": "0.2.0",
  "publisher": "acedatacloud",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model context protocol",
    "ai",
    "copilot",
    "ace data cloud",
    "suno",
    "music",
    "ai music",
    "song generation",
    "lyrics",
    "audio"
  ],
  "galleryBanner": {
    "color": "#0E1117",
    "theme": "dark"
  },
  "homepage": "https://github.com/AceDataCloud/SunoMCP",
  "repository": {
    "type": "git",
    "url": "https://github.com/AceDataCloud/SunoMCP"
  },
  "bugs": {
    "url": "https://github.com/AceDataCloud/SunoMCP/issues"
  },
  "contributes": {
    "mcpServers": {
      "suno": {
        "type": "http",
        "url": "https://suno.mcp.acedata.cloud/mcp",
        "headers": {
          "Authorization": "Bearer ${input:acedatacloud_api_token}"
        }
      }
    },
    "inputs": [
      {
        "type": "promptString",
        "id": "acedatacloud_api_token",
        "description": "Ace Data Cloud API token. Sign in at https://platform.acedata.cloud and create a token in 'API Keys'. Stored securely by VS Code.",
        "password": true
      }
    ]
  }
}
